{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "task": "allow",
    "skill": "allow"
  },
  "mcp": {
    "chainlist": {
      "type": "local",
      "command": ["python3", "/opt/audit/mcp/mcp-chainlist.py"],
      "enabled": true
    },
    "defillama": {
      "type": "local",
      "command": ["python3", "/opt/audit/mcp/mcp-defillama.py"],
      "enabled": true
    }
  }
}
